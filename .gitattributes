# Unity text assets should remain mergeable text.
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.prefab text eol=lf
*.preset text eol=lf
*.shader text eol=lf
*.unity text eol=lf

# C# and config files.
.gitattributes text eol=lf
.gitignore text eol=lf
*.cs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Images tracked by Git LFS.
*.bmp filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text
