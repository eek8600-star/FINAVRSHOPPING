# Normalize text files.
* text=auto

# Unity YAML assets should stay mergeable text, but are high-conflict and must be locked before editing.
*.unity text eol=lf lockable
*.prefab text eol=lf lockable
*.mat text eol=lf lockable
*.asset text eol=lf lockable
*.controller text eol=lf lockable
*.anim text eol=lf lockable
*.overrideController text eol=lf lockable
*.inputactions text eol=lf lockable
*.asmdef text eol=lf
*.asmref text eol=lf
*.meta text eol=lf

# Source and project text.
*.cs text eol=lf
*.shader text eol=lf
*.shadergraph text eol=lf lockable
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary assets through Git LFS.
*.fbx filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.3ds filter=lfs diff=lfs merge=lfs -text
